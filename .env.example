# Ruci configuration
# All settings are stored here. A missing or empty .env triggers first-run setup.
# Swap in a configured .env to restore full state without re-entering anything.

# ── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Auth (auto-generated on first run) ──────────────────────────────────────
SESSION_SECRET=
DASHBOARD_PASSWORD_HASH=

# ── Proxy API key (optional) ─────────────────────────────────────────────────
# If set, clients must send: Authorization: Bearer <PROXY_API_KEY>
# Leave blank for open access.
PROXY_API_KEY=

# ── Providers (managed via dashboard) ────────────────────────────────────────
PROVIDERS=[]
